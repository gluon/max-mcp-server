{
  "manifest_version": "0.1",
  "name": "maxmsp-mcp",
  "version": "0.1.0",
  "description": "Build and drive Max/MSP patches from Claude.",
  "author": { "name": "Julien Bayle" },
  "server": {
    "type": "python",
    "entry_point": "maxmsp_mcp/server.py",
    "mcp_config": {
      "command": "uv",
      "args": ["--directory", "${__dirname}", "run", "python", "-m", "maxmsp_mcp.server"],
      "env": { "MAX_HOST": "127.0.0.1", "MAX_PORT": "7400" }
    }
  }
}
